# OnePay — Environment Variables
# Copy this file to .env and fill in your values

# ── App ──
APP_ENV=production────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET
DEBUG=false

# ── Security ─────────────────────────────────────────────────────────────────
# Generate a DIFFERENT secret from SECRET_KEY above
HMAC_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
# Optional: previous HMAC secret for seamless key rotation
HMAC_SECRET_OLD=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development only)
DATABASE_URL=sqlite:///onepay.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://onepay_user:strongpassword@localhost:5432/onepay

# ── Link Expiry ───────────────────────────────────────────────────────────────
LINK_EXPIRATION_MINUTES=5

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_LIFETIME_HOURS=24
SESSION_TIMEOUT_AUTHENTICATED=30
SESSION_TIMEOUT_UNAUTHENTICATED=60

# ── Account Lockout ───────────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOCKOUT_DURATION_SECS=900

# ── Email (SMTP for password reset) ───────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@yourdomain.com

# ── KoraPay Payment Gateway ───────────────────────────────────────────────────
# Get credentials from: https://korapay.com/dashboard
# Leave empty to run in mock mode (for development/testing)
KORAPAY_SECRET_KEY=
KORAPAY_WEBHOOK_SECRET=
KORAPAY_BASE_URL=https://api.korapay.com
KORAPAY_USE_SANDBOX=false
KORAPAY_TIMEOUT_SECONDS=30
KORAPAY_CONNECT_TIMEOUT=10
KORAPAY_MAX_RETRIES=3

# Note: In production, KORAPAY_SECRET_KEY must start with "sk_live_"
# For sandbox testing, use "sk_test_" prefix and set KORAPAY_USE_SANDBOX=true

# ── Rate Limiting (requests per minute per IP) ─────────────────────────────────
RATE_LIMIT_LINK_CREATE=10
RATE_LIMIT_VERIFY=20
RATE_LIMIT_VERIFY_PAGE_ATTEMPTS=5
RATE_LIMIT_VERIFY_PAGE_WINDOW_SECS=300

# ── Webhook ───────────────────────────────────────────────────────────────────
# Generate a DIFFERENT secret from HMAC_SECRET above
WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

WEBHOOK_TIMEOUT_SECS=10
WEBHOOK_MAX_RETRIES=3

# ── Reverse proxy trust ────────────────────────────────────────────────────────
TRUST_X_FORWARDED_FOR=false
TRUST_X_FORWARDED_PROTO=false

# ── HTTPS enforcement ───────────────────────────────────────────────────────────
ENFORCE_HTTPS=false

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID for Web application
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI format: https://yourdomain.com/auth/google/callback
# For development: http://localhost:5000/auth/google/callback
GOOGLE_REDIRECT_URI=
