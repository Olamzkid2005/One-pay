# OnePay — Environment Variables
# Copy this file to .env and fill in your values

# ── App ──
APP_ENV=production────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET
DEBUG=false

# ── Security ─────────────────────────────────────────────────────────────────
# Generate a DIFFERENT secret from SECRET_KEY above
HMAC_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
# Optional: previous HMAC secret for seamless key rotation
HMAC_SECRET_OLD=

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (default — matches docker-compose.yml credentials)
DATABASE_URL=postgresql://onepay_user:onepay_pass@localhost:5432/onepay
# SQLite (testing only — not for development or production)
# DATABASE_URL=sqlite:///onepay.db

# ── Link Expiry ───────────────────────────────────────────────────────────────
LINK_EXPIRATION_MINUTES=5

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_LIFETIME_HOURS=24
SESSION_TIMEOUT_AUTHENTICATED=30
SESSION_TIMEOUT_UNAUTHENTICATED=60

# ── Account Lockout ───────────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOCKOUT_DURATION_SECS=900

# ── Email (SMTP for password reset) ───────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@yourdomain.com

# ── KoraPay Payment Gateway ───────────────────────────────────────────────────
# Get credentials from: https://korapay.com/dashboard
# Leave empty to run in mock mode (for development/testing)
KORAPAY_SECRET_KEY=
KORAPAY_WEBHOOK_SECRET=
KORAPAY_BASE_URL=https://api.korapay.com
KORAPAY_USE_SANDBOX=false
KORAPAY_TIMEOUT_SECONDS=30
KORAPAY_CONNECT_TIMEOUT=10
KORAPAY_MAX_RETRIES=3

# Note: In production, KORAPAY_SECRET_KEY must start with "sk_live_"
# For sandbox testing, use "sk_test_" prefix and set KORAPAY_USE_SANDBOX=true

# ── Rate Limiting (requests per minute per IP) ─────────────────────────────────
RATE_LIMIT_LINK_CREATE=10
RATE_LIMIT_VERIFY=20
RATE_LIMIT_VERIFY_PAGE_ATTEMPTS=5
RATE_LIMIT_VERIFY_PAGE_WINDOW_SECS=300

# ── API Keys ──────────────────────────────────────────────────────────────────
API_KEY_MAX_PER_USER=10
API_KEY_GENERATION_RATE_LIMIT=5

# ── Inbound Webhooks ──────────────────────────────────────────────────────────
# Generate a DIFFERENT secret from other secrets above
INBOUND_WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# ── API Rate Limits (requests per minute per API key) ─────────────────────────
RATE_LIMIT_API_LINK_CREATE=100
RATE_LIMIT_API_STATUS_CHECK=500

# ── Webhook ───────────────────────────────────────────────────────────────────
# Generate a DIFFERENT secret from HMAC_SECRET above
WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

WEBHOOK_TIMEOUT_SECS=10
WEBHOOK_MAX_RETRIES=3

# ── Reverse proxy trust ────────────────────────────────────────────────────────
TRUST_X_FORWARDED_FOR=false
TRUST_X_FORWARDED_PROTO=false

# ── HTTPS enforcement ───────────────────────────────────────────────────────────
ENFORCE_HTTPS=false

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID for Web application
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI format: https://yourdomain.com/auth/google/callback
# For development: http://localhost:5000/auth/google/callback
GOOGLE_REDIRECT_URI=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# ── VoicePay Integration ──────────────────────────────────────────────────────
# Webhook URL where OnePay will send payment confirmations
VOICEPAY_WEBHOOK_URL=https://voicepay.ng/api/webhooks/onepay
# Generate a DIFFERENT secret from other secrets above
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
VOICEPAY_WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# Sandbox configuration for testing
VOICEPAY_WEBHOOK_URL_SANDBOX=https://sandbox.voicepay.ng/api/webhooks/onepay
VOICEPAY_WEBHOOK_SECRET_SANDBOX=REPLACE_WITH_STRONG_RANDOM_SECRET

# API key for VoicePay to authenticate with OnePay
# Generate this using: python scripts/generate_voicepay_api_key.py --email voicepay@example.com
VOICEPAY_API_KEY=

# Webhook timeout and retry settings
VOICEPAY_WEBHOOK_TIMEOUT_SECS=10
VOICEPAY_WEBHOOK_MAX_RETRIES=3

# Enable/disable VoicePay webhook forwarding (true/false)
VOICEPAY_WEBHOOK_ENABLED=true


# ── Huey Task Queue ────────────────────────────────────────────────────────────
HUEY_DB_PATH=huey.db

# ── Query Performance ─────────────────────────────────────────────────────────
# Warning threshold for number of queries in a single request
QUERY_COUNT_WARN_THRESHOLD=10

# ── CAPTCHA for Password Reset ────────────────────────────────────────────────
# Get credentials from: https://hcaptcha.com/
# Leave empty to disable CAPTCHA verification
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
HCAPTCHA_ENABLED=true

