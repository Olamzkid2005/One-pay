{
  "name": "onepay",
  "version": "1.0.0",
  "description": "OnePay merchant payment platform",
  "scripts": {
    "build:css": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --minify",
    "watch:css": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --watch",
    "build:js": "npx terser static/js/login.js -o static/js/login.min.js --compress --mangle",
    "build": "npm run build:css && npm run build:js"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "terser": "^5.27.0"
  }
}
