# OnePay — Production Environment Variables
# SECURITY: Never commit this file with real values!

# ══════════════════════════════════════════════════════════════════════════════
# CRITICAL SECURITY SETTINGS
# ══════════════════════════════════════════════════════════════════════════════

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_STRING
HMAC_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX_STRING
WEBHOOK_SECRET=REPLACE_WITH_ANOTHER_DIFFERENT_64_CHAR_HEX_STRING

# IMPORTANT: All three secrets MUST be different!
# IMPORTANT: Each secret MUST be at least 32 characters!
# IMPORTANT: Never use placeholder values like "change-this"!

# ══════════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ══════════════════════════════════════════════════════════════════════════════

APP_ENV=production
DEBUG=false

# ══════════════════════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL REQUIRED for production)
# ══════════════════════════════════════════════════════════════════════════════

# PostgreSQL with SSL
DATABASE_URL=postgresql://onepay_user:STRONG_DB_PASSWORD@db.example.com:5432/onepay?sslmode=require

# SECURITY: Never use SQLite in production!
# SECURITY: Use strong database password (20+ chars, mixed case, numbers, symbols)
# SECURITY: Enable SSL/TLS for database connections

# ══════════════════════════════════════════════════════════════════════════════
# HTTPS & REVERSE PROXY
# ══════════════════════════════════════════════════════════════════════════════

ENFORCE_HTTPS=true

# Only enable if behind trusted reverse proxy (nginx, Cloudflare, AWS ALB)
TRUST_X_FORWARDED_FOR=true
TRUST_X_FORWARDED_PROTO=true

# SECURITY: Never enable TRUST_X_FORWARDED_* if directly exposed to internet!

# ══════════════════════════════════════════════════════════════════════════════
# PAYMENT LINK SETTINGS
# ══════════════════════════════════════════════════════════════════════════════

# Link expiration in minutes (5-60 recommended)
LINK_EXPIRATION_MINUTES=5

# Session lifetime in hours (24 recommended)
SESSION_LIFETIME_HOURS=24

# ══════════════════════════════════════════════════════════════════════════════
# ACCOUNT SECURITY
# ══════════════════════════════════════════════════════════════════════════════

# Failed login attempts before lockout
LOGIN_MAX_ATTEMPTS=5

# Lockout duration in seconds (900 = 15 minutes)
LOCKOUT_DURATION_SECS=900

# ══════════════════════════════════════════════════════════════════════════════
# EMAIL (SMTP for password reset)
# ══════════════════════════════════════════════════════════════════════════════

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=YOUR_SMTP_APP_PASSWORD
MAIL_FROM=noreply@yourdomain.com

# Gmail: Use App Password (not regular password)
# AWS SES: Use SMTP credentials from SES console
# SendGrid: Use API key as password

# ══════════════════════════════════════════════════════════════════════════════
# QUICKTELLER / INTERSWITCH API
# ══════════════════════════════════════════════════════════════════════════════

# OAuth credentials from developer.interswitchgroup.com
QUICKTELLER_CLIENT_ID=your_client_id_here
QUICKTELLER_CLIENT_SECRET=your_client_secret_here

# Production endpoint
QUICKTELLER_BASE_URL=https://passport.k8.isw.la

# Sandbox endpoint (for testing)
# QUICKTELLER_BASE_URL=https://qa.interswitchng.com

# ══════════════════════════════════════════════════════════════════════════════
# DYNAMIC TRANSFER (Virtual Accounts)
# ══════════════════════════════════════════════════════════════════════════════

# Get from Quickteller Business Dashboard
MERCHANT_CODE=your_merchant_code
PAYABLE_CODE=your_payable_code

# Production endpoint
VIRTUAL_ACCOUNT_BASE_URL=https://payment-service.k8.isw.la

# Sandbox endpoint (for testing)
# VIRTUAL_ACCOUNT_BASE_URL=https://qa.interswitchng.com

# ══════════════════════════════════════════════════════════════════════════════
# RATE LIMITING
# ══════════════════════════════════════════════════════════════════════════════

# Adjust based on your traffic patterns
RATE_LIMIT_LINK_CREATE=10           # Links per minute per user
RATE_LIMIT_VERIFY=20                # Status polls per minute per IP
RATE_LIMIT_VERIFY_PAGE_ATTEMPTS=5   # Page views per 5 minutes per IP
RATE_LIMIT_VERIFY_PAGE_WINDOW_SECS=300

# SECURITY: Lower limits = better protection, but may impact legitimate users
# SECURITY: Monitor rate_limit logs to tune these values

# ══════════════════════════════════════════════════════════════════════════════
# WEBHOOK SETTINGS
# ══════════════════════════════════════════════════════════════════════════════

# Timeout for webhook HTTP requests (seconds)
WEBHOOK_TIMEOUT_SECS=10

# Maximum retry attempts for failed webhooks
WEBHOOK_MAX_RETRIES=3

# SECURITY: Webhooks are signed with WEBHOOK_SECRET (set above)
# SECURITY: Merchants must verify X-OnePay-Signature header

# ══════════════════════════════════════════════════════════════════════════════
# SECURITY CHECKLIST
# ══════════════════════════════════════════════════════════════════════════════

# Before deploying to production, verify:
# [ ] All secrets are 64+ character random hex strings
# [ ] All secrets are different from each other
# [ ] DATABASE_URL points to PostgreSQL with SSL
# [ ] ENFORCE_HTTPS=true
# [ ] SMTP credentials are valid
# [ ] Quickteller credentials are production (not sandbox)
# [ ] Rate limits are appropriate for your traffic
# [ ] This file is in .gitignore
# [ ] File permissions are 600 (chmod 600 .env)
# [ ] Backups are configured
# [ ] Monitoring is set up
# [ ] Firewall rules are configured
# [ ] SSL certificate is valid

# ══════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT COMMANDS
# ══════════════════════════════════════════════════════════════════════════════

# 1. Install dependencies
#    pip install -r requirements.txt

# 2. Run database migrations
#    alembic upgrade head

# 3. Test configuration
#    python -c "from config import Config; Config.validate(); print('OK')"

# 4. Start application (production)
#    gunicorn -w 4 -b 0.0.0.0:8000 app:app --access-logfile - --error-logfile -

# 5. Verify security headers
#    curl -I https://yourdomain.com | grep -E "(Strict-Transport|Content-Security|X-Frame)"

# ══════════════════════════════════════════════════════════════════════════════
# MONITORING & ALERTS
# ══════════════════════════════════════════════════════════════════════════════

# Set up alerts for:
# - Failed login spikes (>10 per minute)
# - Rate limit violations (>100 per hour)
# - Webhook delivery failures (>10 per hour)
# - Database connection errors
# - Application errors (HTTP 500)
# - Unusual transaction patterns

# ══════════════════════════════════════════════════════════════════════════════
# INCIDENT RESPONSE
# ══════════════════════════════════════════════════════════════════════════════

# If secrets are compromised:
# 1. Generate new secrets immediately
# 2. Update .env with new values
# 3. Keep old HMAC_SECRET as HMAC_SECRET_OLD for 24h grace period
# 4. Restart application (invalidates all sessions)
# 5. Review audit logs: SELECT * FROM audit_logs WHERE created_at > NOW() - INTERVAL '24 hours';
# 6. Notify affected users if data breach occurred

# Emergency contact: security@yourdomain.com
